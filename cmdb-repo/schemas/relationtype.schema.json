{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "kind": {
      "const": "RelationType"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "required": ["name"]
    },
    "spec": {
      "type": "object",
      "properties": {
        "source_type": {
          "type": "string"
        },
        "target_type": {
          "type": "string"
        }
      },
      "required": ["source_type", "target_type"]
    }
  },
  "required": ["kind", "metadata", "spec"]
}
