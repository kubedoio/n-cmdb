{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "kind": {
      "const": "CIType"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "required": ["name"]
    },
    "spec": {
      "type": "object",
      "properties": {
        "attributes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": {
                "enum": ["string", "number", "boolean", "enum"]
              },
              "enum_values": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "readonly": {
                "type": "boolean"
              },
              "required": {
                "type": "boolean"
              }
            },
            "required": ["type"]
          }
        }
      }
    }
  },
  "required": ["kind", "metadata", "spec"]
}
