{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "kind": { "const": "Tenant" },
    "metadata": {
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "spec": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "contact_email": { "type": "string", "format": "email" }
      }
    }
  },
  "required": ["kind", "metadata"]
}
