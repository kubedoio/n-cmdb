{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "kind": {
      "const": "Template"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "required": ["name"]
    },
    "spec": {
      "type": "object",
      "properties": {
        "target_type": {
          "type": "string"
        },
        "defaults": {
          "type": "object"
        },
        "required_relations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "relation_type": {
                "type": "string"
              },
              "target_type": {
                "type": "string"
              }
            },
            "required": ["relation_type", "target_type"]
          }
        }
      },
      "required": ["target_type"]
    }
  },
  "required": ["kind", "metadata", "spec"]
}
