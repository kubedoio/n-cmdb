{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "kind": {
      "const": "MonitoringSource"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "required": ["name"]
    },
    "spec": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["prometheus", "datadog", "cloudwatch"]
        },
        "config": {
          "type": "object"
        }
      },
      "required": ["type"]
    }
  },
  "required": ["kind", "metadata", "spec"]
}
